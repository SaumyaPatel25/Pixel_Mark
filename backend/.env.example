# PixelMark Backend - Environment Template
# Copy this to .env and fill in your details

DATABASE_URL=postgresql+asyncpg://user:password@hostname/dbname
JWT_SECRET_KEY=generate_a_long_random_string_here

# Groq API Key (for AI Triage)
GROQ_API_KEY=YOUR_GROQ_API_KEY

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development

# Encryption Key for BYOK AI Provider Keys (symmetric key, e.g. generated by Fernet.generate_key().decode())
PROVIDER_SECRETS_ENCRYPTION_KEY=

